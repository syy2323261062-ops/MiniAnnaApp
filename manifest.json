{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:mini-notes-summary",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "tags": ["notes", "productivity", "executa", "sampling"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 360, "h": 480 },
        "default_size": { "w": 520, "h": 700 },
        "max_size": { "w": 900, "h": 1100 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "storage": ["get", "set"],
      "tools": ["required:*"],
      "llm": ["complete"]
    },
    "csp_overrides": {
      "script-src": ["'self'"],
      "style-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "seed_storage": {},
    "user_id": 1
  }
}
